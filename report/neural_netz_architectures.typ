#import "@preview/neural-netz:0.3.0": draw-network

= Neural-netz Architecture Figure Drafts

This file is an experimental Typst-native alternative to the PNG architecture figures generated by `scripts/make_report_figures.py`.
It is intentionally kept separate from `main.typ` until the figures are compiled and visually checked.

== DCGAN Generator

#figure(
    draw-network(
        (
            (
                type: "input",
                label: "Latent z",
                channels: ("128",),
                legend: "Latent input",
                name: "z",
                depth: 0,
                width: 0.25,
                show-connection: true,
            ),
            (
                type: "fc",
                label: "\n    Linear \n ",
                channels: ("8192",),
                height: 4.2,
                // A fully connected projection is drawn as a flat 2D layer.
                depth: 0,
                offset: 1,
                name: "project",
                connection-label: "BN + ReLU",
            ),
            (
                type: "custom",
                label: "Reshape",
                channels: ("512", "4x4"),
                width: 0.7,
                height: 3,
                depth: 3,
                offset: 1.5,
                name: "reshape",
                fill: rgb("#dce8ff"),
                opacity: 0.85,
                legend: "Reshape",
            ),
            (
                type: "deconv",
                label: "Deconv",
                channels: ("256", "8x8"),
                height: 4,
                depth: 4,
                widths: (0.5,),
                offset: 0.5,
                name: "d8",
            ),
            (
                type: "deconv",
                label: "Deconv",
                channels: ("128", "16x16"),
                height: 5,
                depth: 5,
                widths: (0.4,),
                offset: 0.8,
                name: "d16",
            ),
            (
                type: "deconv",
                label: "Deconv",
                channels: ("64", "32x32"),
                height: 7,
                depth: 7,
                widths: (0.25,),
                offset: 0.8,
                name: "d32",
            ),
            (
                type: "custom",
                label: "ToRGB + Tanh",
                channels: ("3", "64x64"),
                width: 0.1,
                height: 8,
                depth: 8,
                offset: 1,
                name: "rgb",
                fill: rgb("#f3d6ee"),
                opacity: 0.9,
                legend: "RGB output",
                image: image("assets/dcgan-output.png"),
            ),
        ),
        palette: "cold",
        show-legend: true,
        legend-title: "DCGAN blocks",
        scale: 52%,
        show-relu: true,
    ),
    caption: [DCGAN generator architecture.],
)

